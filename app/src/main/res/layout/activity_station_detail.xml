<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StationDetailActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="84dp"
            android:paddingBottom="16dp">

            <!-- Bandeau hors connexion -->
            <TextView
                android:id="@+id/offline_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:padding="12dp"
                android:textColor="@color/warning_amber"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Mode hors connexion — données du 08/06 14:32"
                tools:visibility="visible" />

            <!-- Nom + statut -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_glass_strong"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/detail_station_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Benjamin Godard - Victor Hugo" />

                <TextView
                    android:id="@+id/detail_station_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    tools:text="Station n° 16107" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/detail_status_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_pill"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Station en service"
                        tools:textColor="@color/velib_green" />

                    <TextView
                        android:id="@+id/detail_last_update"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        tools:text="Mis à jour : il y a 2 min" />
                </LinearLayout>

                <!-- Jauge de remplissage -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/detail_fill_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:indicatorColor="@color/velib_green"
                    app:trackColor="@color/glass_fill_strong"
                    app:trackCornerRadius="6dp"
                    app:trackThickness="10dp"
                    tools:progress="40" />

                <TextView
                    android:id="@+id/detail_fill_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    tools:text="10 vélos sur 35 emplacements" />
            </LinearLayout>

            <!-- Statistiques -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/mechanical_bikes"
                        android:src="@drawable/ic_bike"
                        app:tint="@color/velib_green" />

                    <TextView
                        android:id="@+id/detail_mechanical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/mechanical_bikes"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/electric_bikes"
                        android:src="@drawable/ic_bolt"
                        app:tint="@color/ebike_blue" />

                    <TextView
                        android:id="@+id/detail_ebike"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/electric_bikes"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/free_docks"
                        android:src="@drawable/ic_parking"
                        app:tint="@color/dock_purple" />

                    <TextView
                        android:id="@+id/detail_docks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="25" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/free_docks"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/capacity"
                        android:src="@drawable/ic_map"
                        app:tint="@color/warning_amber" />

                    <TextView
                        android:id="@+id/detail_capacity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="35" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/capacity"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Actions -->
            <Button
                android:id="@+id/button_go_there"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_glass_accent"
                android:drawableStart="@drawable/ic_directions"
                android:drawableTint="@color/text_primary"
                android:paddingHorizontal="20dp"
                android:text="@string/go_there"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_see_on_map"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass"
                    android:text="@string/see_on_map"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/button_share"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass"
                    android:text="@string/share"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- En-tête flottant flouté -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/header_blur"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_glass_strong"
        android:elevation="8dp"
        app:blurOverlayColor="@color/glass_scrim">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/button_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/station_detail"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/button_favorite"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/add_favorite"
                android:src="@drawable/ic_favorite_border"
                app:tint="@color/danger_red" />
        </LinearLayout>
    </eightbitlab.com.blurview.BlurView>
</FrameLayout>
