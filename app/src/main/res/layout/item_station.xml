<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_glass"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_station_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Hôtel de Ville" />

        <TextView
            android:id="@+id/item_station_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_glass_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:textColor="@color/ebike_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="240 m"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/item_station_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/add_favorite"
            android:src="@drawable/ic_favorite_border"
            app:tint="@color/danger_red" />
    </LinearLayout>

    <TextView
        android:id="@+id/item_station_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        tools:text="Mis à jour il y a 2 min" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_station_mechanical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawablePadding="6dp"
            android:gravity="center"
            android:textColor="@color/velib_green"
            android:textSize="14sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_bike"
            app:drawableTint="@color/velib_green"
            tools:text="6" />

        <TextView
            android:id="@+id/item_station_ebike"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawablePadding="6dp"
            android:gravity="center"
            android:textColor="@color/ebike_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_bolt"
            app:drawableTint="@color/ebike_blue"
            tools:text="4" />

        <TextView
            android:id="@+id/item_station_docks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:drawablePadding="6dp"
            android:gravity="center"
            android:textColor="@color/dock_purple"
            android:textSize="14sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_parking"
            app:drawableTint="@color/dock_purple"
            tools:text="12" />
    </LinearLayout>
</LinearLayout>
